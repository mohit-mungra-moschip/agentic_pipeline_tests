# ════════════════════════════════════════════════════════════════════════════
#  RegressionAI · Environment Configuration (Example template)
# ════════════════════════════════════════════════════════════════════════════

# ── Section 1: Model Assignments ─────────────────────────────────────────────
# Provider prefix determines routing + required API key:
#   ollama/       →  Local Ollama        (OLLAMA_BASE_URL, no key)
#   groq/         →  Groq Cloud          (GROQ_API_KEY)
#   openai/       →  OpenAI              (OPENAI_API_KEY)
#   anthropic/    →  Anthropic           (ANTHROPIC_API_KEY)
#   google/       →  Google Gemini       (GEMINI_API_KEY)
#   openrouter/   →  OpenRouter          (OPENROUTER_API_KEY)

# Node 2: Failure Parser
FAILURE_PARSER_MODEL=ollama/llama3.2:1b

# Node 3: File Fetcher
FILE_FETCHER_MODEL=openrouter/openai/gpt-oss-120b:free

# Node 4: Failure Analysis (classify TEST_BUG vs APP_BUG vs ENV_ISSUE vs FLAKY)
FAILURE_ANALYSIS_MODEL=google/gemini-2.0-flash

# Node 5: Self-Healing (auto-fix + re-run, no human approval in CI mode)
SELF_HEALING_MODEL=openrouter/openai/gpt-oss-120b:free

# Node 6: Root Cause Commit Analysis (git blame + git log + LLM)
ROOT_CAUSE_MODEL=groq/llama-3.3-70b-versatile

# Node 7: Action Recommendation Engine (prioritized fix suggestions)
ACTION_RECOMMENDER_MODEL=google/gemini-2.0-flash

# Node 8: Jira Ticketing Agent (wraps existing Jira config)
JIRA_AGENT_MODEL=groq/llama-3.3-70b-versatile

# ── Database (local PostgreSQL on port 55432) ─────────────────────────────────
DATABASE_URL=postgresql+asyncpg://postgres@localhost:5432/regression_ai
DATABASE_URL_SYNC=postgresql://postgres@localhost:55432/regression_ai

# ── CI Mode ───────────────────────────────────────────────────────────────────
# true = fully agentic (no human approval, used in GitHub Actions)
# false = interactive (human approval for self-healing fixes)
CI_MODE=false

# ── Jira Connection ───────────────────────────────────────────────────────────
JIRA_SERVER=https://your-domain.atlassian.net
JIRA_USERNAME=your-email@domain.com
JIRA_PROJECT_KEY=SCRUM
ASSIGNEE_EMAIL=your-email@domain.com

# ── Section 2: Ollama (Local LLM) ────────────────────────────────────────────
OLLAMA_BASE_URL=http://localhost:11434

# ── Section 3: Cloud API Keys ─────────────────────────────────────────────────
GROQ_API_KEY=your_groq_api_key
OPENAI_API_KEY=your_openai_api_key
ANTHROPIC_API_KEY=your_anthropic_api_key
GEMINI_API_KEY=your_gemini_api_key
OPENROUTER_API_KEY=your_openrouter_api_key

# ── Section 4: LangSmith Tracing ─────────────────────────────────────────────
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=your_langsmith_api_key
LANGCHAIN_PROJECT=regression-ai
